# Required for `test/fork` mainnet fork tests. Foundry can load this from `.env` or the process environment.
# Example `.env` entry: MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
MAINNET_RPC_URL=

# Optional: pin the fork block so interest and oracle snapshots stay reproducible across runs.
MAINNET_FORK_BLOCK=
